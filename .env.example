PORT=4000
MONGODB_URI=mongodb://localhost:27017/farm_animals
# Required. Secret used to sign auth JWTs — use a long random string in production.
JWT_SECRET=change-me-to-a-long-random-string
# Optional. Token lifetime (default 30d).
JWT_TTL=30d
# Comma-separated allowed origins for CORS (defaults to "*" for local dev).
CORS_ORIGIN=
# Max requests per 15-minute window per IP (defaults to 1000).
RATE_LIMIT_MAX=1000
